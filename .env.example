# ============================================================
# Predictive Maintenance System - Environment Configuration
# Copy to .env and fill in values before running:
#   cp .env.example .env
# NEVER commit .env to Git (contains credentials)
# ============================================================

# ---- Project ------------------------------------------------
PROJECT_NAME=predictive-maintenance
ENVIRONMENT=production

# ---- API Service (FastAPI) ----------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_LOG_LEVEL=info
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
RETRAIN_API_KEY=CHANGE_ME

# ---- Frontend -----------------------------------------------
FRONTEND_PORT=3000
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_POLL_INTERVAL_MS=5000

# ---- MLflow (DAGsHub hosted) --------------------------------
MLFLOW_TRACKING_URI=https://dagshub.com/<USER>/<REPO>.mlflow
MLFLOW_EXPERIMENT_NAME=predictive-maintenance
MLFLOW_MODEL_NAME=predictive-maintenance-model
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow.db
MLFLOW_DEFAULT_ARTIFACT_ROOT=./mlartifacts

# ---- Model --------------------------------------------------
MODEL_TYPE=xgboost
MAX_INFERENCE_LATENCY_MS=200
MIN_F1_SCORE=0.80
MODEL_STAGE=Production

# ---- PostgreSQL (Airflow metadata DB) -----------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=airflow
POSTGRES_PORT=5432

# ---- Airflow ------------------------------------------------
AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW_PORT=8080
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
AIRFLOW__SCHEDULER__DAG_DIR_LIST_INTERVAL=30
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME

# ---- Prometheus & Grafana -----------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ---- Drift Detection ----------------------------------------
DRIFT_KS_THRESHOLD=0.05
DRIFT_PSI_THRESHOLD=0.2
DRIFT_WINDOW_SIZE=500

# ---- Alerting -----------------------------------------------
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_DRIFT_PERSIST_MINUTES=5

# ---- Security -----------------------------------------------
SECRET_KEY=CHANGE_ME
ENABLE_TLS=false

# ---- DAGsHub credentials ------------------------------------
MLFLOW_TRACKING_USERNAME=CHANGE_ME
MLFLOW_TRACKING_PASSWORD=CHANGE_ME
DAGSHUB_USERNAME=CHANGE_ME
DAGSHUB_TOKEN=CHANGE_ME
