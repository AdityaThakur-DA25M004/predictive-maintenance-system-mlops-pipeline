name: predictive-maintenance

python_env: python_env.yaml

entry_points:
  ingest:
    command: "python -m src.data_ingestion"

  preprocess:
    command: "python -m src.data_preprocessing"

  train:
    parameters:
      n_estimators: {type: int, default: 200}
      max_depth: {type: int, default: 10}
    command: "python -m src.model_training"

  main:
    command: "python -m src.data_ingestion && python -m src.data_preprocessing && python -m src.model_training"
