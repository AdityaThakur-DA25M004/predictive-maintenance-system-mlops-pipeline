name: predictive-maintenance

# Uses the ambient Python environment (the one your venv or Docker
# image already provides). MLflow does not pip-install anything when
# the entry point is invoked with --env-manager=local.
#
# To run any stage:
#   mlflow run . -e train --env-manager=local
#   mlflow run . -e drift_check --env-manager=local
#
# To reproduce the whole pipeline (delegates to DVC):
#   mlflow run . --env-manager=local

entry_points:

  ingest:
    command: "python -m src.data_ingestion"

  preprocess:
    command: "python -m src.data_preprocessing"

  train:
    parameters:
      n_estimators: {type: int, default: 100}
    command: "python -m src.model_training"

  drift_check:
    command: "python -m src.drift_detection"

  # Default entry point — runs the full reproducible pipeline via DVC.
  # DVC handles stage skipping based on file hashes, so this is idempotent.
  main:
    command: "dvc repro"
